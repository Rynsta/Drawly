# Realtime server (keep on 4000 locally so it never clashes with Next on 3000/3001/3002)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Same Wi‑Fi with friends? See env.lan.example — use your LAN IP, not localhost.

# Optional: public site URL for CORS
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated browser origins. If unset in dev, localhost + 127.0.0.1 :3000 are both allowed.
# CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Socket server port (must match NEXT_PUBLIC_SOCKET_URL port)
SOCKET_PORT=4000

# Optional persistence (https://upstash.com)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
