# Copy to `.env.local` when friends on the same Wi‑Fi join YOUR machine.
# Replace 192.168.x.x with your PC’s LAN IP (Windows: ipconfig → IPv4).
#
# Everyone opens http://192.168.x.x:3000 in the browser (not localhost).

NEXT_PUBLIC_SOCKET_URL=http://192.168.x.x:4000
NEXT_PUBLIC_APP_URL=http://192.168.x.x:3000
CLIENT_ORIGIN=http://192.168.x.x:3000
SOCKET_PORT=4000
